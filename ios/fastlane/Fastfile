default_platform(:ios)

platform :ios do
  def api_key
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY"],
      is_key_content_base64: true
    )
  end

  desc "One-time setup: create the App Store distribution certificate + profile and store them in the match repo. Run this once via workflow_dispatch, never on every build."
  lane :bootstrap_signing do
    match(
      type: "appstore",
      api_key: api_key,
      readonly: false
    )
  end

  desc "Build the Flutter app and push a new build to TestFlight"
  lane :beta do
    match(
      type: "appstore",
      api_key: api_key,
      readonly: true
    )

    sh("cd .. && flutter build ios --release --no-codesign")

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.tikcare.lifepulseTestApp" => "match AppStore com.tikcare.lifepulseTestApp"
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
